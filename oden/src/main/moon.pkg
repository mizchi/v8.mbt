import {
  "moonbitlang/core/json" @json,
  "moonbitlang/core/strconv" @strconv,
  "moonbitlang/core/env",
  "moonbitlang/async",
  "moonbitlang/async/fs" @fs,
  "moonbitlang/async/process",
  "moonbitlang/async/stdio" @stdio,
  "mizchi/oden" @oden,
  "mizchi/v8" @v8,
}

options(
  "is-main": true,
  link: { "native": { "cc-link-flags": "${build.MIZCHI_V8_CC_LINK_FLAGS}" } },
  "supported-targets": "native",
)
