import {
  "moonbitlang/async",
  "moonbitlang/core/debug",
}

supported_targets = "native"

options(
  link: {
    "native": {
      "cc-link-flags": "target/rusty_v8_bridge/release/librusty_v8_bridge.link -lc++ -pthread -framework CoreFoundation",
    },
  },
  "pre-build": [
    {
      "command": "bash src/scripts/build-rusty-v8.sh $output",
      "input": "../native/bridge/src/lib.rs",
      "output": "build-stamps/rusty_v8_build.stamp",
    },
  ],
)
